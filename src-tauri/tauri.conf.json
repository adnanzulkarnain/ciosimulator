{
  "productName": "CIO Simulator",
  "version": "1.0.0",
  "identifier": "com.ciosimulator",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8000",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "CIO Simulator — IT Governance Game",
        "width": 1280,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
